# ============================================================
# Finmate - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Números separados por coma (formato WhatsApp)
WHATSAPP_RECIPIENTS=whatsapp:+56912345678,whatsapp:+56987654321

# --- APIs Financieras ---
FINNHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
FMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
ALPHA_VANTAGE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Calendar ---
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_ID=primary

# --- Scheduler ---
WEEKLY_SUMMARY_DAY=sun
WEEKLY_SUMMARY_HOUR=20
WEEKLY_SUMMARY_MINUTE=0
ALERT_CHECK_INTERVAL_MINUTES=30

# --- General ---
TIMEZONE=America/Santiago
PORT=5000
LOG_LEVEL=INFO
